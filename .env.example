PORT=8050
HOST=0.0.0.0
DEBUG=false
CRON_ENABLED=true
# Recarga dos parquets em memória (ms). Padrão: 300000 (5 min). Mínimo: 60000.
DASH_RELOAD_INTERVAL_MS=300000

# BRAPI — token do plano Pro para o endpoint /api/v2/treasury (Tesouro Direto).
# O codigo aceita BRAPI_TOKEN (padrao) ou BRAPI_API_TOKEN como fallback.
# Nunca commitar o valor real — preencha no ambiente (Railway / GitHub Secrets).
BRAPI_TOKEN=
